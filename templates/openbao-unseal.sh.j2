#!/usr/bin/env sh

#Define a timestamp function
timestamp() {
date "+%b %d %Y %T %Z"
}


URL={{ openbao_api_dns_url }}
KEYS_FILE=/etc/openbao/unseal.json

LOG={{ openbao_log }}

SKIP_TLS_VERIFY={{ openbao_tls_skip_verify | ternary("true", "false") }}

if [ true = "$SKIP_TLS_VERIFY" ]
then
  CURL_PARAMS="-sk"
else
  CURL_PARAMS="-s"
fi

# Add timestamp
echo "$(timestamp): OpenBao-unseal started" | tee -a $LOG
echo "-------------------------------------------------------------------------------" | tee -a $LOG

initialised=""

while [ -z "$initialised" ]
do
  sleep 10
  echo "$(timestamp): Waiting for OpenBao to start..." | tee -a $LOG
  initialized=$(curl $CURL_PARAMS $URL/v1/sys/health | jq '.initialized')
done

if [ true = "$initialised" ]
then
  echo "$(timestamp): OpenBao already initialised" | tee -a $LOG
  while true
  do
    status=$(curl $CURL_PARAMS $URL/v1/sys/health | jq '.sealed')
    if [ true = "$status" ]
    then
        echo "$(timestamp): OpenBao Sealed. Trying to unseal" | tee -a $LOG
        # Get keys from json file
        for i in `jq -r '.keys[]' $KEYS_FILE`
          do curl $CURL_PARAMS --request PUT --data "{\"key\": \"$i\"}" $URL/v1/sys/unseal
        done
    sleep 10
    else
        echo "$(timestamp): OpenBao unsealed" | tee -a $LOG
        break
    fi
  done
else
  echo "$(timestamp): OpenBao not initialised yet"
fi
